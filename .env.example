PAYLOAD_SECRET=change_this_super_secret_value

# Use SQLite for local quick start
DATABASE_URL=file:./sistema-gimnasio-payload.db

# Set this to enable Postgres adapter (Neon recommended)
# POSTGRES_URL=postgresql://user:password@host:5432/database

# Enable Vercel Blob storage for media/logo uploads
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_token
